generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum LoginStatus {
  SUCCESS
  FAILED
  TWO_FACTOR_REQUIRED
  TWO_FACTOR_FAILED
  LOCKED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_CHANGED
  EMAIL_CHANGED
  TWO_FACTOR_ENABLE
  TWO_FACTOR_DISABLE
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
  TWO_FACTOR_SUCCESS
  TWO_FACTOR_FAILED
  BACKUP_CODE_USED
  SESSION_REVOKED
  ALL_SESSIONS_REVOKED
  PUBLISH
  UNPUBLISH
  PROFILE_UPDATED
  HERO_UPDATED
  EXPERIENCE_CREATED
  EXPERIENCE_UPDATED
  EXPERIENCE_DELETED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
  SKILL_CREATED
  SKILL_UPDATED
  SKILL_DELETED
  HIGHLIGHT_CREATED
  HIGHLIGHT_UPDATED
  HIGHLIGHT_DELETED
  MESSAGE_READ
  MESSAGE_UNREAD
  MESSAGE_ARCHIVED
  MESSAGE_DELETED
  MEDIA_UPLOADED
  MEDIA_DELETED
  SETTINGS_UPDATED
}

enum MediaKind {
  IMAGE
  DOCUMENT
}

model AdminUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  passwordHash       String
  role               AdminRole @default(EDITOR)
  isActive           Boolean   @default(true)
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  twoFactorEnabledAt DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sessions    AdminSession[]
  loginLogs   AdminLoginLog[]
  auditLogs   AdminAuditLog[]
  backupCodes AdminBackupCode[]
  mediaAssets AdminMediaAsset[]
}

model AdminBackupCode {
  id        String    @id @default(cuid())
  adminId   String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model AdminSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AdminLoginLog {
  id        String      @id @default(cuid())
  userId    String?
  email     String
  status    LoginStatus
  ipAddress String?
  userAgent String?
  reason    String?
  createdAt DateTime    @default(now())

  user AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@index([createdAt])
}

model AdminAuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  summary    String
  beforeJson Json?
  afterJson  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PortfolioProfile {
  id           String   @id @default(cuid())
  name         String
  role         String
  subtitle     String?
  location     String?
  email        String
  phone        String?
  githubUrl    String?
  linkedinUrl  String?
  websiteUrl   String?
  cvUrl        String?
  summary      String
  stackLine    String?
  availability String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PortfolioHero {
  id                 String   @id @default(cuid())
  headlinePrefix     String   @default("Ali Koroglu")
  headlineTemplate   String   @default("systems that")
  animatedWords      Json
  description        String?
  primaryCtaLabel    String?
  primaryCtaHref     String?
  secondaryCtaLabel  String?
  secondaryCtaHref   String?
  currentBuilding    String?
  backgroundImageUrl String?
  visualImageUrl     String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive])
}

model SiteSettings {
  id                        String   @id @default(cuid())
  siteTitle                 String   @default("Ali Koroglu - Full-Stack & Mobile Developer")
  siteDescription           String   @default("Portfolio of Ali Koroglu, a computer engineering senior building .NET, Next.js, Flutter, and Python ML systems.")
  defaultLanguage           String   @default("en")
  maintenanceMode           Boolean  @default(false)
  showAvailabilityBadge     Boolean  @default(true)
  showDownloadCvButton      Boolean  @default(true)
  showGithubButton          Boolean  @default(true)
  showEmailButton           Boolean  @default(true)
  contactFormEnabled        Boolean  @default(true)
  contactRecipientEmail     String?
  footerCopyrightText       String?
  analyticsEnabled          Boolean  @default(false)
  analyticsProvider         String?
  analyticsId               String?
  maintenanceTitle          String?
  maintenanceDescription    String?
  maintenanceExpectedBackAt String?
  maintenanceImageUrl       String?
  ogImageUrl                String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model PortfolioProject {
  id                   String   @id @default(cuid())
  title                String
  slug                 String?
  label                String?
  description          String
  stack                String?
  metric               String?
  githubUrl            String?
  demoUrl              String?
  coverImageUrl        String?
  spotlightTitle       String?
  spotlightSubtitle    String?
  spotlightDescription String?
  spotlightImageUrl    String?
  spotlightMetricLabel String?
  spotlightMetricValue String?
  sortOrder            Int      @default(0)
  isFeatured           Boolean  @default(false)
  isPublished          Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([sortOrder])
  @@index([isPublished])
  @@index([slug])
}

model ContactMessage {
  id         String    @id @default(cuid())
  name       String
  email      String
  subject    String
  message    String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([isRead])
  @@index([archivedAt])
  @@index([createdAt])
}

model AdminMediaAsset {
  id           String    @id @default(cuid())
  fileName     String
  originalName String
  url          String    @unique
  mimeType     String
  size         Int
  kind         MediaKind
  uploadedById String
  createdAt    DateTime  @default(now())

  uploadedBy AdminUser @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([kind])
  @@index([uploadedById])
  @@index([createdAt])
}

model PortfolioExperience {
  id          String   @id @default(cuid())
  title       String
  company     String?
  role        String?
  dateRange   String?
  subtitle    String?
  description String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([isPublished])
}

model PortfolioSkillGroup {
  id          String   @id @default(cuid())
  name        String
  category    String?
  items       Json
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([isPublished])
}

model PortfolioHighlight {
  id          String   @id @default(cuid())
  value       String
  label       String
  sublabel    String?
  quote       String?
  title       String?
  role        String?
  metric      Json?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([isPublished])
}
